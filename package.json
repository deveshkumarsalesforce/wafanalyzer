{
  "name": "wafanalyzer",
  "private": true,
  "version": "1.1.0",
  "description": "WA Log Analyzer for Salesforce Commerce Cloud",
  "main": "electron/main.cjs",
  "author": "",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:app": "npm run build && electron-builder --mac",
    "app": "electron ."
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1"
  },
  "build": {
    "appId": "com.wafanalyzer.app",
    "productName": "WA Log Analyzer",
    "files": [
      "dist",
      "electron",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": null,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    }
  }
}
